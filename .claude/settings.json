{
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git clone *)",
      "Bash(git init *)",
      "Bash(pwd)",
      "Bash(zip *)",
      "Bash(unzip *)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(npm publish *)",
      "Bash(sudo *)"
    ]
  }
}
